# Local .terraform directories and lock files
**/.terraform/*
**/.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files — never commit these
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*tfplan*
*.tfplan

# Terraform CLI config
.terraformrc
terraform.rc

# Temporary kubeconfig generated during apply
kubeconfig_temp

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
